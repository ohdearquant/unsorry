+import Mathlib
+
+theorem quartic_four_var_ge_four_prod (a b c d : ℝ) :
+    4 * a * b * c * d ≤ a ^ 4 + b ^ 4 + c ^ 4 + d ^ 4 := by
+  nlinarith [sq_nonneg (a ^ 2 - b ^ 2), sq_nonneg (c ^ 2 - d ^ 2), sq_nonneg (a * b - c * d),
+    sq_nonneg (a * b + c * d)]
