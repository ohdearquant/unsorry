import Mathlib

theorem gpow_diff_four_pow_sixteen (n : ℤ) : (n - 4) ∣ (n^16 - 4294967296) := by
  exact ⟨n^15 + 4*n^14 + 16*n^13 + 64*n^12 + 256*n^11 + 1024*n^10 + 4096*n^9 + 16384*n^8 + 65536*n^7 + 262144*n^6 + 1048576*n^5 + 4194304*n^4 + 16777216*n^3 + 67108864*n^2 + 268435456*n + 1073741824, by ring⟩
