import Mathlib

theorem gpow_diff_ten_pow_fifteen (n : ℤ) : (n - 10) ∣ (n^15 - 1000000000000000) := by
  exact ⟨n^14 + 10*n^13 + 100*n^12 + 1000*n^11 + 10000*n^10 + 100000*n^9 + 1000000*n^8 + 10000000*n^7 + 100000000*n^6 + 1000000000*n^5 + 10000000000*n^4 + 100000000000*n^3 + 1000000000000*n^2 + 10000000000000*n + 100000000000000, by ring⟩
