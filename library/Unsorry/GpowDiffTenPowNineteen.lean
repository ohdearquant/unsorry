import Mathlib

theorem gpow_diff_ten_pow_nineteen (n : ℤ) : (n - 10) ∣ (n^19 - 10000000000000000000) := by
  exact ⟨n^18 + 10*n^17 + 100*n^16 + 1000*n^15 + 10000*n^14 + 100000*n^13 + 1000000*n^12 + 10000000*n^11 + 100000000*n^10 + 1000000000*n^9 + 10000000000*n^8 + 100000000000*n^7 + 1000000000000*n^6 + 10000000000000*n^5 + 100000000000000*n^4 + 1000000000000000*n^3 + 10000000000000000*n^2 + 100000000000000000*n + 1000000000000000000, by ring⟩
