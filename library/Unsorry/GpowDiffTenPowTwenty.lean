import Mathlib

theorem gpow_diff_ten_pow_twenty (n : ℤ) : (n - 10) ∣ (n^20 - 100000000000000000000) := by
  exact ⟨n^19 + 10*n^18 + 100*n^17 + 1000*n^16 + 10000*n^15 + 100000*n^14 + 1000000*n^13 + 10000000*n^12 + 100000000*n^11 + 1000000000*n^10 + 10000000000*n^9 + 100000000000*n^8 + 1000000000000*n^7 + 10000000000000*n^6 + 100000000000000*n^5 + 1000000000000000*n^4 + 10000000000000000*n^3 + 100000000000000000*n^2 + 1000000000000000000*n + 10000000000000000000, by ring⟩
