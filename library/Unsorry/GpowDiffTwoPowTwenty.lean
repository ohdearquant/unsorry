import Mathlib

theorem gpow_diff_two_pow_twenty (n : ℤ) : (n - 2) ∣ (n^20 - 1048576) := by
  exact ⟨n^19 + 2*n^18 + 4*n^17 + 8*n^16 + 16*n^15 + 32*n^14 + 64*n^13 + 128*n^12 + 256*n^11 + 512*n^10 + 1024*n^9 + 2048*n^8 + 4096*n^7 + 8192*n^6 + 16384*n^5 + 32768*n^4 + 65536*n^3 + 131072*n^2 + 262144*n + 524288, by ring⟩
